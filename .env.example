# ===========================================================================
# POST2HIRE — Environment variables
# Copy this file to .env.local for local development.
# On Vercel: Project Settings > Environment Variables (add each one there).
# NEVER commit .env.local or paste real keys into chat/git.
# ===========================================================================

# --- Supabase (required) ---------------------------------------------------
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key is SERVER-ONLY. Never expose with NEXT_PUBLIC_. Used for
# admin actions, account deletion, and bypassing RLS from trusted server code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider (required) -------------------------------------------------
# "gemini" (recommended, free tier, also used for image generation) or
# "anthropic" (text only — image generation still requires GEMINI_API_KEY).
AI_PROVIDER=gemini

# Google AI Studio > Get API key (aistudio.google.com/apikey) — free tier.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Only required if AI_PROVIDER=anthropic. console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Contact form email (required) -----------------------------------------
# resend.com > API Keys — free tier (100 emails/day)
RESEND_API_KEY=your-resend-api-key
CONTACT_TO_EMAIL=postgethired@gmail.com
# Use Resend's shared sending domain until your own domain is verified in Resend.
CONTACT_FROM_EMAIL=Post2Hire <onboarding@resend.dev>

# --- CAPTCHA (recommended, free) --------------------------------------------
# dash.cloudflare.com > Turnstile > Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin bootstrap ----------------------------------------------------------
# Email that should be promoted to admin on first run (see supabase/schema.sql
# and DEPLOYMENT.md for the exact SQL statement — this var is informational).
ADMIN_BOOTSTRAP_EMAIL=you@example.com
